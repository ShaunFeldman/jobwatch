{
  "_readme": "Run `python watcher.py --verify` once — it hits every board and tells you which tokens are wrong. Fix a broken token by opening the company careers page and reading the URL: job-boards.greenhouse.io/TOKEN, jobs.lever.co/TOKEN, jobs.ashbyhq.com/TOKEN, jobs.smartrecruiters.com/TOKEN. Workday boards: devtools Network tab, find POST to /wday/cxs/TENANT/SITE/jobs. Companies not listed here (Jane Street, Google, Meta, Apple, most banks) are covered by the github_listings sources at the bottom, which aggregate community-tracked postings across hundreds of companies.",

  "interval_seconds": 45,
  "healthcheck_url": "",

  "filters": {
    "include": "(intern|internship|new ?grad|graduate|university|campus|entry.level|early.career|20(26|27|28)|junior|quant|trader|research|software|\\bSWE\\b|developer|engineer|data scien|machine learning|\\bML\\b|\\bAI\\b)",
    "exclude": "(senior|staff|principal|\\blead\\b|manager|director|\\bVP\\b|\\bII\\b|\\bIII\\b|\\bIV\\b|sales|recruit|marketing|account exec|solutions? (consult|architect)|customer success|support engineer|\\bHR\\b|payroll|legal|counsel|physician|nurse|technician|installer|warehouse|driver|mechanic|electrician)",
    "location": ""
  },

