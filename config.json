{
  "_readme": "Run `python watcher.py --verify` once — it hits every board and tells you which tokens are wrong. Fix a broken token by opening the company careers page and reading the URL: job-boards.greenhouse.io/TOKEN, jobs.lever.co/TOKEN, jobs.ashbyhq.com/TOKEN, jobs.smartrecruiters.com/TOKEN. Workday boards: devtools Network tab, find POST to /wday/cxs/TENANT/SITE/jobs (searchText barely filters on workday, so we fetch the 300 newest and let the regex filters do the work). Companies not listed here (Jane Street, Google, Meta, Apple, most banks) are covered by the github_listings/jobright aggregator sources and the linkedin guest-search boards at the bottom. min_interval works across GitHub Actions runs now (last_poll persists via state.json).",

  "interval_seconds": 45,
  "feed_flush_minutes": 0,
  "digest_hour_utc": 13,
  "healthcheck_url": "",

  "filters": {
    "include": "(intern|internship|new ?grad|graduate|university|campus|entry.level|early.career|20(26|27|28)|junior|quant|trader|research|software|\\bSWE\\b|developer|engineer|data scien|machine learning|\\bML\\b|\\bAI\\b)",
    "exclude": "(senior|\\bsr\\b|staff|principal|\\blead\\b|manager|director|\\bVP\\b|\\bII\\b|\\bIII\\b|\\bIV\\b|sales|recruit|marketing|account exec|solutions? (consult|architect)|customer success|support engineer|\\bHR\\b|payroll|legal|counsel|physician|nurse|technician|installer|warehouse|driver|mechanic|electrician)",
    "location": "",
    "exclude_companies": "(selby jennings|anson mccade|harnham|oliver james|hunter bond|durlston|mondrian alpha|robert half|insight global|cybercoders|jobot|actalent|aerotek|teksystems|randstad|michael page|phaidon|glocomms|\\bgqr\\b|averity|storm2|mthree|revolution technologies|motion recruitment|jefferson frank|nigel frank|franklin fitch|understanding recruitment|trilogy international|hamlyn williams|eames consulting|paragon alpha|algo capital|quant capital|barrington james|xcede|kdr talent|(recruit|staffing|talent) (group|partners|solutions|agency)|executive search)"
  },

